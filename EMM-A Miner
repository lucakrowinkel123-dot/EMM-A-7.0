
// Autopilot Test Script

// ============= Settings ==============
// Settings are located entirely in Custom Data.
// Run the script once to generate an initial config.
// =====================================

// ============= Commands ==============
// GPS:Name:X:Y:Z:|Ux,Uy,Uz,Fx,Fy,Fz : sets target position and explicit up/forward vectors
// GPS:Name:X:Y:Z:|Faceup,Faceforward : auto derive up/forward vectors
// stop : disables autopilot and releases controls
// start : enables autopilot (if a target has been set)
// clear : clears target and releases controls
// dumpgps : appends current GPS + orientation snapshot to Custom Data
// minelane;depth : run one mining lane from anchor to depth and return
// minearea;depth;<gps or x,y,z>;<gps or x,y,z> : run distributed lanes over rectangle
// nexthole : skip to the next generated area lane anchor
// cancelmine : stops mining state machine and turns drills off
// SPEEDF <value> : sets forward drilling speed (m/s)
// SPEEDB <value> : sets backing-out speed (m/s)
// MINEH <value> : sets miner lane height footprint (m)
// MINEW <value> : sets miner lane width footprint (m)
// DEPTHMODE <DEFAULT|ORE|ORESTONE> : depth behavior (fixed depth, auto stop on ore depletion, auto incl. stone)
// TOFF r,u,f : sets target offset in local Right,Up,Forward meters
// TOFFRESET : clears target offset
// =====================================

Settings settings;

IMyShipController rc;
ThrusterControl thrust;
GyroControl gyros;
List<IMyShipDrill> drills = new List<IMyShipDrill>();
Vector3D targetPosition = Vector3D.Zero;
bool hasTarget = false;
bool autopilotEnabled = false;
Vector3D desiredForward = Vector3D.Zero;
Vector3D desiredUp = Vector3D.Zero;

enum MiningState
{
    Idle,
    EnterLane,
    DrillForward,
    Backout
}
MiningState miningState = MiningState.Idle;
bool miningEnabled = false;
Vector3D laneAnchor = Vector3D.Zero;
Vector3D drillAxis = Vector3D.Zero;
double laneDepth = 0;
double SPEEDF = 1.0; // forward drilling speed (m/s)
double SPEEDB = 6.0; // backing-out speed (m/s)
double activeMaxSpeed = 0;
double MINEH = 7.5; // miner lane height footprint (m)
double MINEW = 7.5; // miner lane width footprint (m)
enum DepthMode
{
    Default,
    Ore,
    OrePlusStone
}
DepthMode depthMode = DepthMode.Default;
double lastOreSnapshot = 0;
double lastOreGainDepth = 0;
int noOreGainTicks = 0;
const int noOreGainTickLimit = 20;
const double autoDepthNoGainMeters = 2.0;
const double autoDepthExtraCap = 2000.0;
double TOFFR = 0; // target offset Right (m)
double TOFFU = 0; // target offset Up (m)
double TOFFF = 0; // target offset Forward (m)
bool areaMiningMode = false;
List<Vector3D> areaLaneAnchors = new List<Vector3D>();
int areaLaneIndex = 0;
bool retryCurrentLane = false;
Vector3D stuckSamplePos = Vector3D.Zero;
double stuckNoMoveSeconds = 0;
const double stuckTimeoutSeconds = 5.0;
const double stuckMoveThreshold = 0.25;
double secondsPerTick = 1.0 / 60.0;

readonly int echoFrequency = 100; // every 100th game tick
int runtime = 0;

public Program ()
{
    settings = new Settings(Me);
    settings.Load();

    // Prioritize the given cockpit name
    rc = GetBlock<IMyShipController>(settings.cockpitName.Value, true);
    if (rc == null) // Second priority cockpit
        rc = GetBlock<IMyCockpit>();
    if (rc == null) // Third priority remote control
        rc = GetBlock<IMyRemoteControl>();
    if (rc == null) // No cockpits found.
        throw new Exception("No cockpit/remote control found. Set the cockpitName field in settings.");

    thrust = new ThrusterControl(rc, settings.tickSpeed.Value, GetBlocks<IMyThrust>());
    gyros = new GyroControl(rc, settings.tickSpeed.Value, GetBlocks<IMyGyro>());
    drills = GetBlocks<IMyShipDrill>();

    if (settings.tickSpeed.Value == UpdateFrequency.Update10)
        secondsPerTick = 10.0 / 60.0;
    else if (settings.tickSpeed.Value == UpdateFrequency.Update100)
        secondsPerTick = 100.0 / 60.0;

    if (settings.tickSpeed.Value == UpdateFrequency.Update10)
        echoFrequency = 10;
    else if (settings.tickSpeed.Value == UpdateFrequency.Update100)
        echoFrequency = 1;

    Echo("Ready.");
    Runtime.UpdateFrequency = settings.tickSpeed.Value;
}

void ResetMovement()
{
    gyros.Reset();
    thrust.Reset();
}

public void Main (string argument, UpdateType updateSource)
{
    if (updateSource == UpdateType.Update100 || updateSource == UpdateType.Update10 || updateSource == UpdateType.Update1)
    {
        if (runtime % echoFrequency == 0)
            WriteEcho();

        if (miningEnabled)
            UpdateMiningState();

        if (autopilotEnabled && hasTarget)
            Move();
        else
            ResetMovement();
        runtime++;
    }
    else
    {
        RemoteCommand(argument);
    }
}

void WriteEcho()
{
    StringBuilder sb = new StringBuilder();
    sb.AppendLine("Autopilot Test Mode");
    sb.AppendLine(autopilotEnabled ? "State: Enabled" : "State: Disabled");
    if (hasTarget)
        sb.AppendLine($"Target: {targetPosition.ToString("0.00")}");
    else
        sb.AppendLine("Target: <none>");
    sb.AppendLine("Command example:");
    sb.AppendLine("GPS:Site:66288.47:-8270.96:-94039.68:|-0.4942,-0.5045,0.7079,0.5018,0.4994,0.7063");
    sb.AppendLine("dumpgps");
    sb.AppendLine($"Arrival tolerance: {settings.arrivalTolerance.Value:0.00} m");
    sb.AppendLine($"Orientation tolerance: {settings.orientationToleranceDeg.Value:0.00} deg");
    sb.AppendLine($"Mining: {miningState}");
    sb.AppendLine($"SPEEDF: {SPEEDF:0.00} m/s");
    sb.AppendLine($"SPEEDB: {SPEEDB:0.00} m/s");
    sb.AppendLine($"MINEH/MINEW: {MINEH:0.00}/{MINEW:0.00} m");
    sb.AppendLine($"Depth mode: {depthMode}");
    sb.AppendLine($"TOFF R/U/F: {TOFFR:0.00}/{TOFFU:0.00}/{TOFFF:0.00} m");
    if (areaMiningMode && areaLaneAnchors.Count > 0)
        sb.AppendLine($"Area lane: {areaLaneIndex + 1}/{areaLaneAnchors.Count}");
    sb.AppendLine("Faceforward = look toward target");
    sb.AppendLine("Faceup = align up to gravity-up (or current up in space)");

    Echo(sb.ToString());
}


void Move ()
{
    Vector3D worldOffset = GetTargetOffsetWorld();
    Vector3D position = rc.GetPosition() + worldOffset;
    Vector3D toTarget = targetPosition - position;
    double tolerance = Math.Max(0.05, settings.arrivalTolerance.Value);

    Vector3D forward = desiredForward;
    if (forward == Vector3D.Zero && toTarget.LengthSquared() > 0.001)
        forward = Vector3D.Normalize(toTarget);

    Vector3D up = desiredUp;
    if (up == Vector3D.Zero)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rc.WorldMatrix.Up;
    }

    gyros.FaceVectors(forward, up);

    bool atPosition = toTarget.LengthSquared() < tolerance * tolerance;
    bool aligned = IsOrientationAligned(forward, up, settings.orientationToleranceDeg.Value);
    if (atPosition)
    {
        thrust.Reset();
        if (aligned)
            gyros.Reset();
        return;
    }

    double maxSpeed = activeMaxSpeed > 0 ? activeMaxSpeed : settings.maxSpeed.Value;
    Vector3D rcTarget = targetPosition - worldOffset;
    thrust.ApplyAccel(thrust.ControlPosition(rcTarget, Vector3D.Zero, maxSpeed));
}

Vector3D GetTargetOffsetWorld()
{
    MatrixD wm = rc.WorldMatrix;
    return wm.Right * TOFFR + wm.Up * TOFFU + wm.Forward * TOFFF;
}

bool IsOrientationAligned(Vector3D forward, Vector3D up, double toleranceDeg)
{
    double tol = Math.Max(0.1, toleranceDeg) * Math.PI / 180.0;
    double minDot = Math.Cos(tol);
    MatrixD wm = rc.WorldMatrix;

    if (forward.LengthSquared() > 0.001)
    {
        Vector3D f = Vector3D.Normalize(forward);
        if (Vector3D.Dot(wm.Forward, f) < minDot)
            return false;
    }
    if (up.LengthSquared() > 0.001)
    {
        Vector3D u = Vector3D.Normalize(up);
        if (Vector3D.Dot(wm.Up, u) < minDot)
            return false;
    }
    return true;
}

void RemoteCommand (string command)
{
    if (string.IsNullOrWhiteSpace(command))
        return;

    string trimmed = command.Trim();
    if (trimmed.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
    {
        if (!TryParseGpsCommand(trimmed, out targetPosition, out desiredForward, out desiredUp))
        {
            Echo("Invalid GPS command format.");
            return;
        }
        hasTarget = true;
        autopilotEnabled = true;
        WriteEcho();
        return;
    }

    if (trimmed.StartsWith("SPEEDF ", StringComparison.OrdinalIgnoreCase))
    {
        double v;
        if (double.TryParse(trimmed.Substring(7).Trim(), out v) && v > 0)
        {
            SPEEDF = v;
            Echo($"SPEEDF set to {SPEEDF:0.00} m/s");
        }
        else
            Echo("Invalid SPEEDF value.");
        return;
    }

    if (trimmed.StartsWith("SPEEDB ", StringComparison.OrdinalIgnoreCase))
    {
        double v;
        if (double.TryParse(trimmed.Substring(7).Trim(), out v) && v > 0)
        {
            SPEEDB = v;
            Echo($"SPEEDB set to {SPEEDB:0.00} m/s");
        }
        else
            Echo("Invalid SPEEDB value.");
        return;
    }
    if (trimmed.StartsWith("MINEH ", StringComparison.OrdinalIgnoreCase))
    {
        double v;
        if (double.TryParse(trimmed.Substring(6).Trim(), out v) && v > 0)
        {
            MINEH = v;
            Echo($"MINEH set to {MINEH:0.00} m");
        }
        else
            Echo("Invalid MINEH value.");
        return;
    }
    if (trimmed.StartsWith("MINEW ", StringComparison.OrdinalIgnoreCase))
    {
        double v;
        if (double.TryParse(trimmed.Substring(6).Trim(), out v) && v > 0)
        {
            MINEW = v;
            Echo($"MINEW set to {MINEW:0.00} m");
        }
        else
            Echo("Invalid MINEW value.");
        return;
    }
    if (trimmed.StartsWith("DEPTHMODE ", StringComparison.OrdinalIgnoreCase))
    {
        string mode = trimmed.Substring(10).Trim().ToUpperInvariant();
        if (mode == "DEFAULT")
            depthMode = DepthMode.Default;
        else if (mode == "ORE")
            depthMode = DepthMode.Ore;
        else if (mode == "ORESTONE")
            depthMode = DepthMode.OrePlusStone;
        else
        {
            Echo("Invalid DEPTHMODE. Use DEFAULT, ORE, or ORESTONE.");
            return;
        }
        Echo($"DEPTHMODE set to {depthMode}");
        return;
    }
    if (trimmed.StartsWith("TOFF ", StringComparison.OrdinalIgnoreCase))
    {
        Vector3D off;
        if (TryParseVector3(trimmed.Substring(5).Trim(), out off))
        {
            TOFFR = off.X;
            TOFFU = off.Y;
            TOFFF = off.Z;
            Echo($"TOFF set. R/U/F = {TOFFR:0.00}/{TOFFU:0.00}/{TOFFF:0.00} m");
        }
        else
            Echo("Invalid TOFF. Use: TOFF r,u,f");
        return;
    }

    switch (trimmed.ToLower())
    {
        case "stop":
            Runtime.UpdateFrequency = UpdateFrequency.None;
            ResetMovement();
            autopilotEnabled = false;
            Echo("Stopped.");
            break;
        case "start":
            Runtime.UpdateFrequency = settings.tickSpeed.Value;
            autopilotEnabled = true;
            WriteEcho();
            break;
        case "clear":
            hasTarget = false;
            desiredForward = Vector3D.Zero;
            desiredUp = Vector3D.Zero;
            miningEnabled = false;
            miningState = MiningState.Idle;
            areaMiningMode = false;
            areaLaneAnchors.Clear();
            areaLaneIndex = 0;
            retryCurrentLane = false;
            activeMaxSpeed = 0;
            SetDrills(false);
            ResetMovement();
            WriteEcho();
            break;
        case "dumpgps":
            DumpCurrentGpsToCustomData();
            break;
        case "cancelmine":
            miningEnabled = false;
            miningState = MiningState.Idle;
            areaMiningMode = false;
            areaLaneAnchors.Clear();
            areaLaneIndex = 0;
            retryCurrentLane = false;
            activeMaxSpeed = 0;
            SetDrills(false);
            Echo("Mining cancelled.");
            break;
        case "nexthole":
            NextHole();
            break;
        case "toffreset":
            TOFFR = 0;
            TOFFU = 0;
            TOFFF = 0;
            Echo("TOFF reset to 0,0,0.");
            break;
        default:
            if (trimmed.StartsWith("minelane;", StringComparison.OrdinalIgnoreCase))
                StartSingleLaneMining(trimmed);
            else if (trimmed.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
                StartAreaMining(trimmed);
            break;
    }
}

void StartSingleLaneMining(string command)
{
    string[] args = command.Split(';');
    if (args.Length < 2)
    {
        Echo("Usage: minelane;depth");
        return;
    }

    double depth;
    if (!double.TryParse(args[1], out depth) || depth <= 0)
    {
        Echo("Invalid depth.");
        return;
    }

    laneDepth = depth;
    laneAnchor = hasTarget ? targetPosition : rc.GetPosition();
    areaMiningMode = false;
    areaLaneAnchors.Clear();
    areaLaneIndex = 0;
    retryCurrentLane = false;

    Vector3D fwd = desiredForward;
    if (fwd.LengthSquared() < 0.001)
        fwd = rc.WorldMatrix.Forward;
    drillAxis = Vector3D.Normalize(fwd);

    if (desiredUp.LengthSquared() < 0.001)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        desiredUp = gravity.LengthSquared() > 0.001 ? Vector3D.Normalize(-gravity) : rc.WorldMatrix.Up;
    }

    desiredForward = drillAxis;
    targetPosition = laneAnchor;
    activeMaxSpeed = SPEEDB;
    hasTarget = true;
    autopilotEnabled = true;
    miningEnabled = true;
    miningState = MiningState.EnterLane;
    ResetDepthAutoTracker();
    Echo($"Mining lane started. Depth={laneDepth:0.00}m");
}

void StartAreaMining(string command)
{
    // minearea;depth;<gps or x,y,z>;<gps or x,y,z>
    string[] args = command.Split(';');
    if (args.Length < 4)
    {
        Echo("Usage: minearea;depth;<gps or x,y,z>;<gps or x,y,z>");
        return;
    }

    double depth;
    if (!double.TryParse(args[1], out depth) || depth <= 0)
    {
        Echo("Invalid depth.");
        return;
    }

    Vector3D leftUpper;
    Vector3D rightBottom;
    if (!TryParsePoint(args[2], out leftUpper) || !TryParsePoint(args[3], out rightBottom))
    {
        Echo("Invalid rectangle points. Use GPS:Name:X:Y:Z: or x,y,z");
        return;
    }

    Vector3D up = desiredUp;
    if (up.LengthSquared() < 0.001)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        up = gravity.LengthSquared() > 0.001 ? Vector3D.Normalize(-gravity) : rc.WorldMatrix.Up;
    }
    up = Vector3D.Normalize(up);

    Vector3D forward = desiredForward;
    if (forward.LengthSquared() < 0.001)
        forward = rc.WorldMatrix.Forward;
    forward = Vector3D.Normalize(forward);

    Vector3D right = Vector3D.Cross(forward, up);
    if (right.LengthSquared() < 0.001)
        right = rc.WorldMatrix.Right;
    right = Vector3D.Normalize(right);

    areaLaneAnchors = BuildRectangleLaneAnchors(leftUpper, rightBottom, up, right, MINEH, MINEW);
    if (areaLaneAnchors.Count == 0)
    {
        Echo("Unable to generate area lanes.");
        return;
    }

    laneDepth = depth;
    drillAxis = forward;
    desiredUp = up;
    desiredForward = drillAxis;

    areaMiningMode = true;
    areaLaneIndex = 0;
    retryCurrentLane = false;
    laneAnchor = areaLaneAnchors[areaLaneIndex];
    targetPosition = laneAnchor;
    activeMaxSpeed = SPEEDB;
    hasTarget = true;
    autopilotEnabled = true;
    miningEnabled = true;
    miningState = MiningState.EnterLane;
    ResetDepthAutoTracker();

    Echo($"Area mining started. Lanes={areaLaneAnchors.Count}, depth={laneDepth:0.00}m");
}

List<Vector3D> BuildRectangleLaneAnchors(Vector3D leftUpper, Vector3D rightBottom, Vector3D up, Vector3D right, double laneHeight, double laneWidth)
{
    List<Vector3D> anchors = new List<Vector3D>();
    if (laneHeight <= 0 || laneWidth <= 0)
        return anchors;

    Vector3D down = -up;
    Vector3D delta = rightBottom - leftUpper;
    double height = Math.Abs(Vector3D.Dot(delta, down));
    double width = Math.Abs(Vector3D.Dot(delta, right));

    // Use center points for each lane so the lane footprint stays inside bounds.
    // Choose lane counts with Ceil() so we never leave uncovered gaps.
    int rows = Math.Max(1, (int)Math.Ceiling(height / laneHeight));
    int cols = Math.Max(1, (int)Math.Ceiling(width / laneWidth));

    // First/last lane centers are inset by half lane size from each border.
    // Steps are compressed (overlap) to absorb odd remainders while keeping edges covered.
    double rowStep = rows > 1 ? (height - laneHeight) / (rows - 1) : 0;
    double colStep = cols > 1 ? (width - laneWidth) / (cols - 1) : 0;
    double rowStart = rows > 1 ? laneHeight * 0.5 : height * 0.5;
    double colStart = cols > 1 ? laneWidth * 0.5 : width * 0.5;

    for (int r = 0; r < rows; r++)
    {
        Vector3D rowOrigin = leftUpper + down * (rowStart + r * rowStep);
        bool reverse = (r % 2) == 1;
        for (int c = 0; c < cols; c++)
        {
            int ci = reverse ? (cols - 1 - c) : c;
            Vector3D anchor = rowOrigin + right * (colStart + ci * colStep);
            anchors.Add(anchor);
        }
    }

    return anchors;
}

bool TryParseVector3(string csv, out Vector3D value)
{
    value = Vector3D.Zero;
    string[] t = csv.Split(',');
    if (t.Length != 3)
        return false;
    double x, y, z;
    if (!double.TryParse(t[0].Trim(), out x))
        return false;
    if (!double.TryParse(t[1].Trim(), out y))
        return false;
    if (!double.TryParse(t[2].Trim(), out z))
        return false;
    value = new Vector3D(x, y, z);
    return true;
}

bool TryParsePoint(string text, out Vector3D value)
{
    value = Vector3D.Zero;
    if (string.IsNullOrWhiteSpace(text))
        return false;

    string t = text.Trim();
    if (t.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
    {
        string[] parts = t.Split(':');
        if (parts.Length < 5)
            return false;

        double x, y, z;
        if (!double.TryParse(parts[2], out x))
            return false;
        if (!double.TryParse(parts[3], out y))
            return false;
        if (!double.TryParse(parts[4], out z))
            return false;

        value = new Vector3D(x, y, z);
        return true;
    }

    return TryParseVector3(t, out value);
}

void UpdateMiningState()
{
    switch (miningState)
    {
        case MiningState.EnterLane:
            targetPosition = laneAnchor;
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDB;
            if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
            {
                SetDrills(true);
                ResetStuckMonitor();
                ResetDepthAutoTracker();
                miningState = MiningState.DrillForward;
            }
            break;
        case MiningState.DrillForward:
            targetPosition = laneAnchor + drillAxis * GetLaneTargetDepth();
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDF;
            if (CheckStuckInLane())
            {
                retryCurrentLane = true;
                miningState = MiningState.Backout;
                Echo("Stuck detected. Returning to anchor and retrying lane.");
            }
            else if (ShouldFinishDrillForward())
                miningState = MiningState.Backout;
            break;
        case MiningState.Backout:
            targetPosition = laneAnchor;
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDB;
            if (IsAtTargetPosition(targetPosition))
            {
                if (!retryCurrentLane)
                    SetDrills(false);
                if (retryCurrentLane)
                {
                    retryCurrentLane = false;
                    miningState = MiningState.EnterLane;
                    Echo($"Retrying lane {areaLaneIndex + 1}/{Math.Max(1, areaLaneAnchors.Count)}");
                }
                else if (areaMiningMode && areaLaneIndex + 1 < areaLaneAnchors.Count)
                {
                    areaLaneIndex++;
                    laneAnchor = areaLaneAnchors[areaLaneIndex];
                    ResetDepthAutoTracker();
                    miningState = MiningState.EnterLane;
                    Echo($"Proceeding to lane {areaLaneIndex + 1}/{areaLaneAnchors.Count}");
                }
                else
                {
                    miningEnabled = false;
                    miningState = MiningState.Idle;
                    autopilotEnabled = false;
                    activeMaxSpeed = 0;
                    areaMiningMode = false;
                    areaLaneAnchors.Clear();
                    areaLaneIndex = 0;
                    Echo("Mining operation complete.");
                }
            }
            break;
    }
}

void ResetStuckMonitor()
{
    stuckSamplePos = rc.GetPosition();
    stuckNoMoveSeconds = 0;
}

void ResetDepthAutoTracker()
{
    lastOreSnapshot = GetOreAmount(depthMode == DepthMode.OrePlusStone);
    lastOreGainDepth = 0;
    noOreGainTicks = 0;
}

double GetLaneProgressDepth()
{
    return Math.Max(0, Vector3D.Dot(rc.GetPosition() - laneAnchor, drillAxis));
}

double GetLaneTargetDepth()
{
    if (depthMode == DepthMode.Default)
        return laneDepth;
    return laneDepth + autoDepthExtraCap;
}

bool ShouldFinishDrillForward()
{
    double depthProgress = GetLaneProgressDepth();
    if (depthMode == DepthMode.Default)
        return depthProgress >= laneDepth || IsAtTargetPosition(targetPosition);

    bool includeStone = depthMode == DepthMode.OrePlusStone;
    double oreNow = GetOreAmount(includeStone);

    if (oreNow > lastOreSnapshot + 0.01)
    {
        lastOreSnapshot = oreNow;
        lastOreGainDepth = depthProgress;
        noOreGainTicks = 0;
    }
    else if (depthProgress >= laneDepth && (depthProgress - lastOreGainDepth) >= autoDepthNoGainMeters)
    {
        noOreGainTicks++;
    }

    if (depthProgress >= laneDepth + autoDepthExtraCap)
        return true;

    return depthProgress >= laneDepth && noOreGainTicks >= noOreGainTickLimit;
}

double GetOreAmount(bool includeStone)
{
    List<IMyTerminalBlock> blocks = new List<IMyTerminalBlock>();
    GridTerminalSystem.GetBlocksOfType(blocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId && b.HasInventory);

    double total = 0;
    List<MyInventoryItem> items = new List<MyInventoryItem>();
    foreach (var block in blocks)
    {
        int invCount = block.InventoryCount;
        for (int i = 0; i < invCount; i++)
        {
            var inv = block.GetInventory(i);
            if (inv == null)
                continue;
            items.Clear();
            inv.GetItems(items);
            foreach (var item in items)
            {
                if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                    continue;
                if (!includeStone && string.Equals(item.Type.SubtypeId, "Stone", StringComparison.OrdinalIgnoreCase))
                    continue;
                total += (double)item.Amount;
            }
        }
    }

    return total;
}

bool CheckStuckInLane()
{
    double moved = Vector3D.DistanceSquared(rc.GetPosition(), stuckSamplePos);
    if (moved < stuckMoveThreshold * stuckMoveThreshold)
    {
        stuckNoMoveSeconds += secondsPerTick;
        if (stuckNoMoveSeconds >= stuckTimeoutSeconds)
        {
            ResetStuckMonitor();
            return true;
        }
    }
    else
    {
        stuckSamplePos = rc.GetPosition();
        stuckNoMoveSeconds = 0;
    }
    return false;
}

void NextHole()
{
    if (areaLaneAnchors.Count == 0)
    {
        Echo("No area plan loaded. Start with minearea first.");
        return;
    }
    if (areaLaneIndex + 1 >= areaLaneAnchors.Count)
    {
        Echo("Already at last hole.");
        return;
    }

    SetDrills(false);
    areaLaneIndex++;
    areaMiningMode = true;
    laneAnchor = areaLaneAnchors[areaLaneIndex];
    targetPosition = laneAnchor;
    desiredForward = drillAxis.LengthSquared() > 0.001 ? drillAxis : rc.WorldMatrix.Forward;
